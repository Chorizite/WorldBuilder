<UserControl
    x:Class="WorldBuilder.Modules.Landscape.Views.Components.BookmarksPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:WorldBuilder.Converters"
    xmlns:i="using:Avalonia.Xaml.Interactivity"
    xmlns:ia="using:Avalonia.Xaml.Interactions.Core"
    xmlns:idd="using:Avalonia.Xaml.Interactions.DragAndDrop"
    xmlns:landscape="clr-namespace:WorldBuilder.Modules.Landscape.ViewModels"
    xmlns:viewmodels="clr-namespace:WorldBuilder.ViewModels"
    xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:ctrl="clr-namespace:WorldBuilder.Controls"
    x:CompileBindings="False"
    x:DataType="landscape:BookmarksPanelViewModel">
    <UserControl.Resources>
        <conv:SearchSourceConverter x:Key="SearchSourceConverter" />
        <conv:TreeListSearchSourceConverter x:Key="TreeListSearchSourceConverter" />
        
        <!-- Chevron Path Resources -->
        <DataTemplate x:Key="CollapsedChevronTemplate">
            <Path Data="{StaticResource TreeDataGridItemCollapsedChevronPathData}"
                  Fill="{DynamicResource SemiColorText0}"
                  Opacity="0.6"
                  Stretch="Uniform"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center" />
        </DataTemplate>
        
        <DataTemplate x:Key="ExpandedChevronTemplate">
            <Path Data="{StaticResource TreeDataGridItemExpandedChevronPathData}"
                  Fill="{DynamicResource SemiColorText0}"
                  Opacity="0.6"
                  Stretch="Uniform"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center" />
        </DataTemplate>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto, *">
        <Grid Grid.Row="0" Margin="4" ColumnDefinitions="Auto, *">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                <Button Command="{Binding AddBookmarkCommand}" ToolTip.Tip="{Binding AddBookmarkHotkey, StringFormat='Add New Bookmark ({0})'}">
                    <icons:MaterialIcon Kind="Plus" Width="16" Height="16" />
                </Button>
                <Button Command="{Binding AddFolderCommand}" ToolTip.Tip="Add New Folder">
                    <icons:MaterialIcon Kind="FolderPlus" Width="16" Height="16" />
                </Button>
                <Button
                    Command="{Binding DeleteBookmarkCommand}"
                    CommandParameter="{Binding Bookmarks.SelectedItem}"
                    IsEnabled="{Binding Bookmarks.SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}"
                    ToolTip.Tip="Delete Selected Bookmark">
                    <icons:MaterialIcon Kind="Delete" Width="16" Height="16" />
                </Button>
                <Button
                    x:Name="GoToButton"
                    Command="{Binding GoToBookmarkCommand}"
                    CommandParameter="{Binding Bookmarks.SelectedItem}"
                    IsEnabled="{Binding Bookmarks.SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}"
                    ToolTip.Tip="Go To Selected Bookmark">
                    <icons:MaterialIcon Kind="ArrowRight" Width="16" Height="16" />
                </Button>
            </StackPanel>
            <TextBox Grid.Column="1" 
                     Text="{Binding SearchText}" 
                     Watermark="Search bookmarks..." 
                     Margin="4,0,0,0" />
        </Grid>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid Margin="4,0,0,0">
                <!-- Overlay for drop indicator -->
                <Canvas x:Name="DropIndicatorCanvas" IsHitTestVisible="False" />

                <ListBox x:Name="BookmarkTreeView" 
                         SelectedItem="{Binding Bookmarks.SelectedItem}"
                         KeyDown="OnTreeDataGridKeyDown">
                    <ListBox.ItemsSource>
                        <MultiBinding Converter="{StaticResource TreeListSearchSourceConverter}">
                            <Binding Path="SearchText" />
                            <Binding Path="Bookmarks" />
                            <Binding Path="SearchResults" />
                        </MultiBinding>
                    </ListBox.ItemsSource>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
					    <DataTemplate>
                            <Border Background="Transparent" MinHeight="28">
				                <Grid ColumnDefinitions="Auto,20,*">
                                    <Border Width="{Binding Indent}" />
						            <Button Grid.Column="1"
                                            Command="{Binding ToggleExpandedCommand}"
                                            IsVisible="{Binding HasChildren}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            MinHeight="0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Width="10" Height="10">
                                            <Grid>
                                                <ContentControl Content="{Binding}"
                                                               ContentTemplate="{StaticResource CollapsedChevronTemplate}"
                                                               IsVisible="{Binding !IsExpanded}" />
                                                <ContentControl Content="{Binding}"
                                                               ContentTemplate="{StaticResource ExpandedChevronTemplate}"
                                                               IsVisible="{Binding IsExpanded}" />
                                            </Grid>
                                            <Button.Styles>
                                                <Style Selector=":pointerover /template/ ContentPresenter">
                                                    <Setter Property="Background" Value="Transparent" />
                                                </Style>
                                            </Button.Styles>
                                        </Button>
                                    <StackPanel Grid.Column="2" Spacing="8" Orientation="Horizontal" Background="Transparent"
                                        PointerEntered="OnBookmarkItemPointerEntered" 
                                        PointerExited="OnBookmarkItemPointerExited">
                                        <icons:MaterialIcon 
                                            Width="16" 
                                            Height="16" 
                                            Kind="{Binding Node.IconKind}"
                                            Foreground="{Binding Node.IconColor}"
                                            Opacity="{Binding Node.IconOpacity}"
                                            VerticalAlignment="Center" />
						                <TextBlock Text="{Binding Node.Name}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Border>						    
                        </DataTemplate>	
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
