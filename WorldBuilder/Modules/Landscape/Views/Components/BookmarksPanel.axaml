<UserControl
    x:Class="WorldBuilder.Modules.Landscape.Views.Components.BookmarksPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:WorldBuilder.Converters"
    xmlns:i="using:Avalonia.Xaml.Interactivity"
    xmlns:ia="using:Avalonia.Xaml.Interactions.Core"
    xmlns:idd="using:Avalonia.Xaml.Interactions.DragAndDrop"
    xmlns:landscape="clr-namespace:WorldBuilder.Modules.Landscape.ViewModels"
    xmlns:viewmodels="clr-namespace:WorldBuilder.ViewModels"
    xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    x:CompileBindings="False"
    x:DataType="landscape:BookmarksPanelViewModel">
    <UserControl.Resources>
        <conv:SearchSourceConverter x:Key="SearchSourceConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto, *">
        <Grid Grid.Row="0" Margin="4" ColumnDefinitions="Auto, *">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                <Button Command="{Binding AddBookmarkCommand}" ToolTip.Tip="{Binding AddBookmarkHotkey, StringFormat='Add New Bookmark ({0})'}">
                    <icons:MaterialIcon Kind="Plus" Width="16" Height="16" />
                </Button>
                <Button Command="{Binding AddFolderCommand}" ToolTip.Tip="Add New Folder">
                    <icons:MaterialIcon Kind="FolderPlus" Width="16" Height="16" />
                </Button>
                <Button
                    Command="{Binding DeleteBookmarkCommand}"
                    CommandParameter="{Binding SelectedItem}"
                    IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}"
                    ToolTip.Tip="Delete Selected Bookmark">
                    <icons:MaterialIcon Kind="Delete" Width="16" Height="16" />
                </Button>
                <Button
                    x:Name="GoToButton"
                    Command="{Binding GoToBookmarkCommand}"
                    CommandParameter="{Binding SelectedItem}"
                    IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}"
                    ToolTip.Tip="Go To Selected Bookmark">
                    <icons:MaterialIcon Kind="ArrowRight" Width="16" Height="16" />
                </Button>
            </StackPanel>
            <TextBox Grid.Column="1" 
                     Text="{Binding SearchText}" 
                     Watermark="Search bookmarks..." 
                     Margin="4,0,0,0" />
        </Grid>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid Margin="4,0,0,0">
                <!-- Overlay for drop indicator -->
                <Canvas x:Name="DropIndicatorCanvas" IsHitTestVisible="False" />
                
                <TreeDataGrid
                    x:Name="BookmarkTreeView"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    KeyDown="OnTreeDataGridKeyDown"
                    ShowColumnHeaders="False">
                    <TreeDataGrid.Resources>
                        
                        <!-- Template for bookmark/folder cells -->
                        <DataTemplate x:Key="BookmarkCellTemplate">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,8" VerticalAlignment="Center"
                                        PointerEntered="OnBookmarkItemPointerEntered" 
                                        PointerExited="OnBookmarkItemPointerExited">
                                <icons:MaterialIcon 
                                    Width="16" 
                                    Height="16" 
                                    Kind="{Binding IconKind}"
                                    Foreground="{Binding IconColor}"
                                    Opacity="{Binding IconOpacity}"
                                    VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </TreeDataGrid.Resources>
                    <TreeDataGrid.Source>
                        <MultiBinding Converter="{StaticResource SearchSourceConverter}">
                            <Binding Path="SearchText" />
                            <Binding Path="Bookmarks" />
                            <Binding Path="SearchResults" />
                        </MultiBinding>
                    </TreeDataGrid.Source>
                    <TreeDataGrid.Styles>
                        <Style Selector="TreeDataGridRow">
                            <Setter Property="MinHeight" Value="16" />
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </TreeDataGrid.Styles>
                    <TreeDataGrid.DataTemplates>
						<TreeDataTemplate x:DataType="viewmodels:BookmarkFolder" ItemsSource="{Binding Items}">
                            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource BookmarkCellTemplate}" />
                        </TreeDataTemplate>
                        <DataTemplate x:DataType="viewmodels:Bookmark">
                            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource BookmarkCellTemplate}" />
                        </DataTemplate>
                    </TreeDataGrid.DataTemplates>
                </TreeDataGrid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
