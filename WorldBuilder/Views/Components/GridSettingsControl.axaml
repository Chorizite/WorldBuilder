<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="using:WorldBuilder.Modules.DatBrowser.ViewModels"
             mc:Ignorable="d"
             x:Class="WorldBuilder.Views.Components.GridSettingsControl"
             x:DataType="vm:GridBrowserViewModel">
    <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="Items Per Row:" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource SemiColorText1}"/>
        <Slider Minimum="2" Maximum="24" Value="{Binding ItemsPerRow, FallbackValue=8}" Width="150" VerticalAlignment="Center"/>
        <TextBlock Text="{Binding ItemsPerRow, FallbackValue=8}" VerticalAlignment="Center" Width="20" FontSize="12"/>

        <CheckBox Content="Wireframe" IsChecked="{Binding ShowWireframe, FallbackValue=False}" IsVisible="{Binding Is3DViewAndNotEnvironment}" VerticalAlignment="Center" Margin="10,0,0,0"/>
    </StackPanel>
</UserControl>
