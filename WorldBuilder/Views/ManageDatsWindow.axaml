<Window
    x:Class="WorldBuilder.Views.ManageDatsWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:WorldBuilder.Views"
    xmlns:vm="using:WorldBuilder.ViewModels"
    Title="Manage DAT Repository"
    Width="900"
    Height="600"
    d:DesignHeight="600"
    d:DesignWidth="900"
    x:CompileBindings="True"
    x:DataType="vm:ManageDatsViewModel"
    Icon="/Assets/worldbuilder.ico"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <views:ManageDatsView />
</Window>
