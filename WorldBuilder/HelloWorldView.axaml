<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
    x:Class="WorldBuilder.HelloWorldView"
	Background="Transparent">

	<Grid RowDefinitions="Auto,Auto">
		<TextBox
			Name="MyTextBox"
            Width="300"
            Height="100"
            FontSize="18"
            TextAlignment="Left"
            Text="Type your notes here"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            Grid.Row="0" />
		<StackPanel Orientation="Vertical" Margin="0,20,0,20" Grid.Row="1">
			<Button Content="Hello button 1" Name="Button1" HorizontalAlignment="Left" MinWidth="100" />
			<Button Content="Hello button 2" Name="Button2" HorizontalAlignment="Left" MinWidth="100" />
		</StackPanel>
	</Grid>
</UserControl>